rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Opal media: public read, authenticated write (admins curate, users contribute their own opals)
    match /opals/{opalId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Challenge reveal media: public read, admin-only write
    match /challenges/{challengeId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Poster version images: public read, authenticated write
    match /posters/{posterId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
